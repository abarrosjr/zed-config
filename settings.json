{
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Catppuccin Latte"
  },
  "proxy": "",
  "show_edit_predictions": false,
  "edit_predictions": {
    "allow_data_collection": "no"
  },
  "disable_ai": true,
  "agent": {
    "enable_feedback": false,
    "button": false,
    "favorite_models": [],
    "model_parameters": []
  },
  "collaboration_panel": {
    "button": false
  },
  "git_panel": {
    "tree_view": true,
    "sort_by_path": false
  },
  "outline_panel": {
    "git_status": true,
    "folder_icons": true,
    "button": false
  },
  "pane_split_direction_horizontal": "down",
  "pane_split_direction_vertical": "right",
  "active_pane_modifiers": {
    "border_size": 4.0,
    "inactive_opacity": 0.7
  },
  "window_decorations": "client",
  "focus_follows_mouse": {
    "enabled": false
  },
  "bottom_dock_layout": "contained",
  "tabs": {
    "git_status": false
  },
  "tab_bar": {
    "show": false
  },
  "title_bar": {
    "button_layout": "platform_default",
    "show_menus": false,
    "show_user_picture": true,
    "show_user_menu": false,
    "show_sign_in": false,
    "show_project_items": false,
    "show_branch_name": true,
    "show_branch_status_icon": false
  },
  "debugger": {
    "button": true
  },
  "status_bar": {
    "show_active_file": false,
    "active_language_button": true
  },
  "project_panel": {
    "indent_guides": {
      "show": "never"
    },
    "git_status_indicator": true,
    "diagnostic_badges": false,
    "bold_folder_labels": true,
    "auto_fold_dirs": true,
    "starts_open": true,
    "auto_reveal_entries": true,
    "git_status": true,
    "indent_size": 20.0,
    "entry_spacing": "comfortable",
    "default_width": 240.0,
    "dock": "right",
    "button": true
  },
  "search": {
    "button": false
  },
  "diagnostics": {
    "button": false
  },
  "terminal": {
    "flexible": true,
    "dock": "bottom",
    "button": true
  },
  "search_wrap": true,
  "soft_wrap": "none",
  "auto_indent_on_paste": false,
  "auto_indent": "none",
  "vim": {
    "use_regex_search": true
  },
  "toolbar": {
    "selections_menu": false,
    "quick_actions": false,
    "breadcrumbs": true,
    "agent_review": false
  },
  "minimap": {
    "show": "always"
  },
  "scrollbar": {
    "axes": {
      "horizontal": false
    },
    "selected_text": true,
    "search_results": true,
    "cursors": true,
    "show": "auto"
  },
  "gutter": {
    "breakpoints": true,
    "runnables": true
  },
  "relative_line_numbers": "disabled",
  "fast_scroll_sensitivity": 3.0,
  "scroll_beyond_last_line": "off",
  "autosave": {
    "after_delay": {
      "milliseconds": 100
    }
  },
  "agent_ui_font_size": 17.0,
  "ui_font_weight": 400.0,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "auto_update": true,
  "session": {
    "trust_all_worktrees": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "ui_font_size": 17.0,
  "buffer_font_size": 17.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Espresso (Blur) [Heavy]"
  }
}
